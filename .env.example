# Hugging Face Hub configuration
# Copy to .env and fill in your values

# Required for uploads
HF_TOKEN=your_huggingface_token_here

# Optional: base directories (relative to project root or absolute)
HF_MODELS_DIR=models
HF_DATASETS_DIR=datasets

# Optional: default org/username when repo ID has no slash (e.g. my-model -> org/my-model)
HF_DEFAULT_ORG=

# Optional: Hub endpoint (e.g. mirror for China)
HF_ENDPOINT_DEFAULT=https://hf-mirror.com
